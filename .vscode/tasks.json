{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"label": "npm: build",
			"script": "build",
			"group": "build",
			"problemMatcher": "$tsc",
		},
		{
			"type": "npm",
			"label": "npm: watch",
			"script": "watch",
			"group": "build",
			"problemMatcher": "$tsc-watch",
			"isBackground": true
		},
		{
			"type": "npm",
			"label": "npm: build:browser",
			"script": "build:browser",
			"group": "build",
			"problemMatcher": "$tsc",
		},
		{
			"type": "npm",
			"script": "serve:test",
			"label": "npm: serve:test",
			"isBackground": true,
			"problemMatcher": {
				"owner": "custom",
				"pattern": {
					"regexp": ".*"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Server ready at http://127\\.0\\.0\\.1:8123/test/browser-test\\.html"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"type": "shell",
			"label": "launch browser test: edge",
			"windows": {
				"command": "start msedge --new-window --remote-debugging-port=9222 --user-data-dir=\"${workspaceFolder}\\.vscode\\edge-debug-profile\" http://127.0.0.1:8123/test/browser-test.html"
			},
			"problemMatcher": [],
			"dependsOn": ["prepare browser test"]
		},
		{
			"type": "shell",
			"label": "launch browser test: chrome",
			"windows": {
				"command": "start chrome --new-window --remote-debugging-port=9223 --user-data-dir=\"${workspaceFolder}\\.vscode\\chrome-debug-profile\" http://127.0.0.1:8123/test/browser-test.html"
			},
			"problemMatcher": [],
			"dependsOn": ["prepare browser test"]
		},
		{
			"type": "shell",
			"label": "prepublish",
			"command": "git add .; npm version ${input:version} --force",
			"windows": {
				"command": "git add . & npm version ${input:version} --force",
			},
			"problemMatcher": [],
			"dependsOn": ["npm: build", "npm: build:browser"]
		},
		{
			"type": "shell",
			"label": "PUBLISH",
			"command": "npm publish --access public",
			"problemMatcher": [],
			"dependsOn": "prepublish"
		},
		{
			"type": "shell",
			"label": "PACKAGE",
			"command": "npm pack",
			"problemMatcher": [],
			"dependsOn": ["npm: build", "npm: build:browser"]
		},
		{
			"type": "shell",
			"label": "prepare browser test",
			"dependsOn": ["npm: build", "npm: build:browser", "npm: serve:test"],
			"problemMatcher": []
		},
	],
	"inputs": [
		{
			"id": "version",
			"description": "Version bump:",
			"type": "pickString",
			"options": ["patch", "minor", "major"],
			"default": "none"
		},
	]
}
