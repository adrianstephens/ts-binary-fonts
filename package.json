{
	"name": "@isopodlabs/binary_fonts",
	"description": "A package for reading various font files with TypeScript.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/adrianstephens/ts-binary-fonts.git"
	},
	"main": "./dist/index.js",
	"files": [
		"dist/**/*.{js,d.ts}",
		"README.md"
	],
	"scripts": {
		"postinstall": "ts-patch install && copy-file node_modules/@isopodlabs/binary/scripts/transform.ts scripts/transform.ts",
		"build": "tsc",
		"watch": "tsc -watch -p ./",
		"lint": "eslint \"src/**/*.ts\"",
		"link": "npm link @isopodlabs/binary @isopodlabs/maths @isopodlabs/xml"
	},
	"keywords": [
		"binary",
		"typescript",
		"data",
		"read",
		"write"
	],
	"author": "Adrian Stephens",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.13.8",
		"@typescript-eslint/eslint-plugin": "^8.26.0",
		"@typescript-eslint/parser": "^8.26.0",
		"eslint": "^9.21.0",
		"ts-node": "^10.9.2",
		"ts-patch": "^3.3.0",
		"typescript-eslint": "^8.26.0"
	},
	"dependencies": {
		"@isopodlabs/binary": "^1.7.1",
		"@isopodlabs/maths": "^1.0.0",
		"@isopodlabs/xml": "^1.2.0"
	},
	"version": "0.5.0"
}
