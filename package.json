{
	"name": "@isopodlabs/binary_fonts",
	"description": "A package for reading various font files with TypeScript.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/adrianstephens/ts-binary-fonts.git"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"browser": "./dist/browser.js",
	"exports": {
		".": {
			"browser": "./dist/browser.js",
			"default": "./dist/index.js"
		},
		"./browser": "./dist/browser.js"
	},
	"files": [
		"dist/**/*.{js,d.ts}",
		"README.md"
	],
	"scripts": {
		"prepare": "ts-patch install && copy-file node_modules/@isopodlabs/binary/scripts/transform.ts scripts/transform.ts",
		"build": "tsc -p ./",
		"build:browser": "esbuild src/browser.ts --bundle --minify --platform=browser --format=esm --target=es2022 --sourcemap --outfile=dist/browser.mjs",
		"serve:test": "node test/serve.js",
		"watch": "tsc -watch -p ./",
		"lint": "eslint \"src/**/*.ts\"",
		"link": "npm link @isopodlabs/binary @isopodlabs/maths @isopodlabs/xml",
		"update": "npm install @isopodlabs/binary@latest @isopodlabs/maths @isopodlabs/xml@latest"
	},
	"keywords": [
		"binary",
		"typescript",
		"data",
		"read",
		"write"
	],
	"author": "Adrian Stephens",
	"license": "MIT",
	"dependencies": {
		"@isopodlabs/binary": "^1.11.0",
		"@isopodlabs/maths": "^1.0.0",
		"@isopodlabs/xml": "^1.2.0"
	},
	"version": "0.6.3"
}
